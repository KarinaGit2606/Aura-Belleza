{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portafolio2",
  "compatibility_date": "2026-07-07",
  "compatibility_flags": ["nodejs_compat"],
  "main": "src/server.ts",
  "main": "dist/server/server.js",
  "assets": {
    "directory": "dist/client",
    "binding": "ASSETS"
  }
}
